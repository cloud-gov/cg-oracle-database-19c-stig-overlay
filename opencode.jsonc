  //     "bash": {
  //       "*": "deny",
  //       "git log *": "allow",
  //       "git diff *": "allow",
  //       "git show *": "allow"
  //     },
  //     "task": "deny",
  //     "webfetch": "deny"
  //   }
  // }
  //
  // Documentation Writer Agent:
  // "docs-writer": {
  //   "description": "Technical documentation specialist. Cannot modify code.",
  //   "mode": "subagent",
  //   "model": "usai/claude_4_5_sonnet",
  //   "temperature": 0.5,
  //   "permission": {
  //     "read": "allow",
  //     "edit": {
  //       "*.py": "deny",
  //       "*.js": "deny",
  //       "*.ts": "deny",
  //       "*.md": "allow",
  //       "*.mdx": "allow",
  //       "docs/**": "allow"
  //     },
  //     "bash": "deny"
  //   }
  // }
  //
  // Compliance Mode (Custom Primary Agent):
  // "compliance-mode": {
  //   "description": "FedRAMP/FISMA compliance-focused development.",
  //   "mode": "primary",
  //   "model": "usai/claude_4_5_sonnet",
  //   "temperature": 0.3,
  //   "color": "#0050d8",
  //   "prompt": "You are a federal compliance specialist."
  // }

